<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.RECORD_AUDIO" />
    <uses-feature android:name="android.hardware.usb.host" android:required="true" />

    <application
        android:label="AACP Demo"
        android:theme="@style/Theme.AppCompat.Light.NoActionBar"
        android:allowBackup="false">

        <activity
            android:name=".CarPlayActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:screenOrientation="landscape"
            android:configChanges="orientation|screenSize|keyboardHidden">

            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>

            <!--
                USB Accessory intent filter:
                Khi iPhone cắm vào, Android sẽ hỏi user có muốn mở app này không.
                android.hardware.usb.action.USB_DEVICE_ATTACHED chỉ dùng cho USB Host.
            -->
            <intent-filter>
                <action android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED" />
            </intent-filter>

            <meta-data
                android:name="android.hardware.usb.action.USB_DEVICE_ATTACHED"
                android:resource="@xml/device_filter" />
        </activity>
    </application>
</manifest>
