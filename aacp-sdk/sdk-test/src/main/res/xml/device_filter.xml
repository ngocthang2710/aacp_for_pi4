<?xml version="1.0" encoding="utf-8"?>
<!--
    USB device filter: chỉ match Apple devices (VID=0x05AC).
    Android sẽ show app selection dialog khi bất kỳ Apple USB device nào cắm vào.
-->
<resources>
    <usb-device vendor-id="1452" />
    <!-- 1452 = 0x05AC decimal = Apple Inc. vendor ID -->
</resources>
